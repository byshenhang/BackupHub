# Backup-Hub 配置文件
# 复制此文件为 .env 并填入实际值

# 服务配置
HOST=0.0.0.0
PORT=8000
DEBUG=false

# 数据库
DATABASE_URL=sqlite:///data/backup-hub.db

# 凭证加密主密钥（Fernet key，可通过 python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())" 生成）
SECRET_KEY=

# GitLab 配置
GITLAB_URL=https://gitlab.example.com
GITLAB_TOKEN=your-gitlab-token-here

# 阿里云 OSS 配置（可选，也可在 Web 界面配置存储目标）
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_ENDPOINT=
OSS_BUCKET=

# 日志级别
LOG_LEVEL=INFO
