# Backup-Hub 配置文件
# 复制此文件为 .env 并填入实际值

# 服务配置
HOST=0.0.0.0
PORT=8000
DEBUG=false
TIMEZONE=Asia/Shanghai

# 数据库
DATABASE_URL=sqlite:///data/backup-hub.db

# 凭证加密主密钥（Fernet key）
# 生成方式：python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_KEY=

# 登录密码（必填，否则无法登录）
LOGIN_PASSWORD=

# Session 加密密钥（可选，留空则自动生成临时密钥，生产环境建议配置）
SESSION_SECRET=

# GitLab Token（GitLab URL 在 Web 管理后台按任务配置）
GITLAB_TOKEN=your-gitlab-token-here

# GitHub Token 建议在「应用设置」中保存；此项仅作为可选环境变量回退
GITHUB_TOKEN=

# 访问 GitHub 需要代理时可启用；Docker Desktop 中请改用 host.docker.internal
# HTTP_PROXY=http://127.0.0.1:10808
# HTTPS_PROXY=http://127.0.0.1:10808

# WebDAV（123 网盘服务地址通常为 https://webdav.123pan.cn/webdav/）
WEBDAV_URL=
WEBDAV_USERNAME=
WEBDAV_PASSWORD=
WEBDAV_REMOTE_PATH=/backup-hub/

# 日志级别
LOG_LEVEL=INFO

# Docker 对外端口
BACKUP_HUB_PORT=8010
