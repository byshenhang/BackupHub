# Backup-Hub 配置文件
# 复制此文件为 .env 并填入实际值

# 服务配置
HOST=0.0.0.0
PORT=8000
DEBUG=false

# 数据库
DATABASE_URL=sqlite:///data/backup-hub.db

# 凭证加密主密钥（Fernet key）
# 生成方式：python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_KEY=

# 登录密码（必填，否则无法登录）
LOGIN_PASSWORD=

# Session 加密密钥（可选，留空则自动生成临时密钥，生产环境建议配置）
SESSION_SECRET=

# GitLab 默认配置（可在 Web 界面按任务覆盖）
GITLAB_URL=https://gitlab.example.com
GITLAB_TOKEN=your-gitlab-token-here

# 日志级别
LOG_LEVEL=INFO
